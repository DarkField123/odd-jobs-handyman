---
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import { AdminGuard } from '../../../components/auth/AdminGuard';
import { AccountLayout } from '../../../components/account/AccountLayout';
import QuoteSubmissionsManager from '../../../components/editors/QuoteSubmissionsManager.tsx';
import '../../../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Quote Submissions | ${SITE_TITLE}`} description="Manage quote submissions" />
	</head>
	<body>
		<AdminGuard client:load>
			<AccountLayout client:load currentPath="/account/editor/quotes">
				<QuoteSubmissionsManager client:load />
			</AccountLayout>
		</AdminGuard>
	</body>
</html>
