---
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import { AdminGuard } from '../../../components/auth/AdminGuard';
import { AccountLayout } from '../../../components/account/AccountLayout';
import ExpensesManager from '../../../components/editors/ExpensesManager';
import '../../../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Expenses | ${SITE_TITLE}`} description="Track business expenses" />
	</head>
	<body>
		<AdminGuard client:load>
			<AccountLayout client:load currentPath="/account/editor/expenses">
				<ExpensesManager client:load />
			</AccountLayout>
		</AdminGuard>
	</body>
</html>
