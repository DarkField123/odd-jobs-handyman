---
import BaseHead from '../../../components/BaseHead.astro';
import { SITE_TITLE } from '../../../consts';
import { AdminGuard } from '../../../components/auth/AdminGuard';
import { AccountLayout } from '../../../components/account/AccountLayout';
import ReportsManager from '../../../components/editors/ReportsManager';
import '../../../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Reports | ${SITE_TITLE}`} description="Financial reports and summaries" />
	</head>
	<body>
		<AdminGuard client:load>
			<AccountLayout client:load currentPath="/account/editor/reports">
				<ReportsManager client:load />
			</AccountLayout>
		</AdminGuard>
	</body>
</html>
