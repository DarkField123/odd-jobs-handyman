---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import { SITE_TITLE, CONTACT } from '../consts';
---

<BaseLayout title="About Us" description="Learn about Odd Jobs - your trusted local handyman service.">
  <!-- Hero Section -->
  <section class="about-hero">
    <div class="container">
      <h1>About {SITE_TITLE}</h1>
      <p class="hero-subtitle">Your trusted local handyman for over 10 years</p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="about-story">
    <div class="container">
      <div class="story-grid">
        <div class="story-content">
          <h2>Our Story</h2>
          <p>
            {SITE_TITLE} was founded with a simple mission: to provide reliable, high-quality handyman
            services to homeowners in our community. What started as a one-man operation has grown
            into a trusted local business serving hundreds of satisfied customers.
          </p>
          <p>
            We believe that every job, no matter how small, deserves the same level of care and
            attention. From fixing a leaky tap to renovating a bathroom, we approach each project
            with professionalism and pride in our work.
          </p>
          <p>
            Our team brings together decades of combined experience in various trades, allowing
            us to handle almost any home repair or improvement task you can throw at us.
          </p>
        </div>
        <div class="story-image">
          <div class="image-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
            <span>Team Photo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="about-values">
    <div class="container">
      <h2>Our Values</h2>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3>Quality First</h3>
          <p>We never cut corners. Every job is completed to the highest standard, using quality materials and proven techniques.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>Reliable & Punctual</h3>
          <p>When we say we'll be there, we'll be there. We respect your time and always aim to complete work on schedule.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3>Clear Communication</h3>
          <p>No surprises. We explain what needs to be done, how long it will take, and what it will cost before we start.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3>Fair Pricing</h3>
          <p>Honest, upfront quotes with no hidden fees. We believe in fair pricing for quality work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coverage Section -->
  <section class="about-coverage">
    <div class="container">
      <div class="coverage-grid">
        <div class="coverage-content">
          <h2>Areas We Serve</h2>
          <p>
            We're proud to serve {CONTACT.address.city} and the surrounding areas within a 15-mile radius.
            Our local knowledge means we can respond quickly and understand the specific needs of homes in our community.
          </p>
          <ul class="area-list">
            <li>{CONTACT.address.city}</li>
            <li>Salford</li>
            <li>Stockport</li>
            <li>Trafford</li>
            <li>Bolton</li>
            <li>Bury</li>
          </ul>
          <p class="coverage-note">
            Not sure if we cover your area? <a href="/quote">Submit a quote request</a> and we'll let you know.
          </p>
        </div>
        <div class="coverage-stats">
          <div class="stat">
            <span class="stat-number">10+</span>
            <span class="stat-label">Years Experience</span>
          </div>
          <div class="stat">
            <span class="stat-number">500+</span>
            <span class="stat-label">Happy Customers</span>
          </div>
          <div class="stat">
            <span class="stat-number">100%</span>
            <span class="stat-label">Satisfaction Rate</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    padding: 5rem 0;
    text-align: center;
  }

  .about-hero h1 {
    font-size: 3rem;
    color: var(--text-white);
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  /* Story Section */
  .about-story {
    padding: 5rem 0;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .story-content h2 {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .story-content p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .image-placeholder {
    background: var(--bg-light);
    border-radius: var(--radius-lg);
    padding: 6rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--text-light);
    border: 2px dashed var(--border-light);
  }

  /* Values Section */
  .about-values {
    padding: 5rem 0;
    background: var(--bg-light);
  }

  .about-values h2 {
    font-size: 2rem;
    text-align: center;
    color: var(--text-primary);
    margin-bottom: 3rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .value-card {
    background: var(--bg-white);
    padding: 2rem;
    border-radius: var(--radius-md);
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .value-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    width: 70px;
    height: 70px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-lighter);
    border-radius: var(--radius-full);
    color: var(--accent);
  }

  .value-card h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .value-card p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Coverage Section */
  .about-coverage {
    padding: 5rem 0;
  }

  .coverage-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .coverage-content h2 {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .coverage-content > p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .area-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 2rem;
    list-style: none;
    margin-bottom: 1.5rem;
  }

  .area-list li {
    padding: 0.5rem 0;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-light);
  }

  .coverage-note {
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .coverage-note a {
    color: var(--accent);
    font-weight: 600;
  }

  .coverage-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat {
    background: var(--bg-light);
    padding: 2rem 1rem;
    border-radius: var(--radius-md);
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .story-grid,
    .coverage-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .coverage-stats {
      max-width: 400px;
    }
  }

  @media (max-width: 600px) {
    .about-hero {
      padding: 3rem 0;
    }

    .about-hero h1 {
      font-size: 2rem;
    }

    .about-story,
    .about-values,
    .about-coverage {
      padding: 3rem 0;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }

    .coverage-stats {
      grid-template-columns: 1fr;
      max-width: none;
    }
  }
</style>
