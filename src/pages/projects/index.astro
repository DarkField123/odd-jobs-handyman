---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/sections/CTABanner.astro';

// Placeholder projects - will be replaced with Firebase data
const projects = [
  {
    id: 'kitchen-renovation',
    title: 'Kitchen Tap Replacement',
    description: 'Replaced old leaky taps with modern mixer taps including new isolation valves.',
    category: 'Plumbing',
    location: 'Manchester',
    image: 'https://images.unsplash.com/photo-1585704032915-c3400ca199e7?w=600',
    date: 'January 2024',
  },
  {
    id: 'bathroom-lights',
    title: 'Bathroom Lighting Upgrade',
    description: 'Installed LED downlights and extractor fan with timer in main bathroom.',
    category: 'Electrical',
    location: 'Salford',
    image: 'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=600',
    date: 'January 2024',
  },
  {
    id: 'garden-fence',
    title: 'Garden Fence Repair',
    description: 'Replaced damaged fence panels and posts after storm damage.',
    category: 'Carpentry',
    location: 'Stockport',
    image: 'https://images.unsplash.com/photo-1504148455328-c64695cc6952?w=600',
    date: 'December 2023',
  },
  {
    id: 'living-room-paint',
    title: 'Living Room Repaint',
    description: 'Full redecoration including walls, ceiling, and woodwork.',
    category: 'Painting',
    location: 'Trafford',
    image: 'https://images.unsplash.com/photo-1562259949-e8e7689d7828?w=600',
    date: 'December 2023',
  },
];

const categories = ['All', ...new Set(projects.map(p => p.category))];
---

<BaseLayout title="Projects" description="Browse our completed handyman projects and see examples of our work.">
  <section class="page-header">
    <div class="container">
      <h1>Our Projects</h1>
      <p>Take a look at some of our recently completed work.</p>
    </div>
  </section>

  <section class="projects-section">
    <div class="container">
      <!-- Filter Buttons -->
      <div class="filter-buttons">
        {categories.map((cat) => (
          <button class="filter-btn" data-category={cat === 'All' ? 'all' : cat}>
            {cat}
          </button>
        ))}
      </div>

      <!-- Projects Grid -->
      <div class="projects-grid">
        {projects.map((project) => (
          <article class="project-card" data-category={project.category}>
            <div class="project-image">
              <img src={project.image} alt={project.title} loading="lazy" />
              <span class="project-category">{project.category}</span>
            </div>
            <div class="project-content">
              <div class="project-meta">
                <span class="project-location">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  {project.location}
                </span>
                <span class="project-date">{project.date}</span>
              </div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const projectCards = document.querySelectorAll('.project-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active button
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Filter projects
      const category = btn.dataset.category;
      projectCards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Set first button as active
  filterBtns[0]?.classList.add('active');
</script>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2.5rem;
    color: var(--text-white);
    margin-bottom: 0.5rem;
  }

  .page-header p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .projects-section {
    padding: 4rem 0;
  }

  /* Filter Buttons */
  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .filter-btn {
    padding: 0.625rem 1.25rem;
    background: var(--bg-light);
    color: var(--text-secondary);
    border: 2px solid transparent;
    border-radius: var(--radius-full);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    color: var(--accent);
    border-color: var(--accent-light);
  }

  .filter-btn.active {
    background: var(--accent);
    color: var(--text-white);
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    background: var(--bg-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .project-image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-category {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.375rem 0.75rem;
    background: var(--accent);
    color: var(--text-white);
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
  }

  .project-content {
    padding: 1.5rem;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    font-size: 0.875rem;
  }

  .project-location {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--text-secondary);
  }

  .project-date {
    color: var(--text-light);
  }

  .project-content h3 {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .project-content p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .page-header {
      padding: 3rem 0;
    }

    .page-header h1 {
      font-size: 2rem;
    }

    .projects-section {
      padding: 2rem 0;
    }

    .filter-buttons {
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    .filter-btn {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }
  }
</style>
