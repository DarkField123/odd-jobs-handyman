---
import { SITE_TITLE, CONTACT, HOURS, SOCIAL_LINKS, NAV_LINKS, SERVICES } from '../consts';

const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-content">
    <!-- Branding Column -->
    <div class="footer-column footer-brand">
      <a href="/" class="footer-logo">
        <img src="/logo.svg" alt={SITE_TITLE} class="footer-logo-img" />
      </a>
      <p class="footer-tagline">
        Professional handyman services for all your home repair and improvement needs.
      </p>
      <div class="social-links">
        <a href={SOCIAL_LINKS.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Quick Links Column -->
    <div class="footer-column">
      <h4>Quick Links</h4>
      <ul>
        {NAV_LINKS.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Services Column -->
    <div class="footer-column">
      <h4>Our Services</h4>
      <ul>
        {SERVICES.slice(0, 5).map((service) => (
          <li><a href={`/quote?service=${service.id}`}>{service.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact Column -->
    <div class="footer-column">
      <h4>Contact Us</h4>
      <ul class="contact-list">
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <span>{CONTACT.address.city}</span>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <a href="/quote">Request a Quote</a>
        </li>
      </ul>

      <!-- Hours -->
      <h4 class="hours-title">Hours</h4>
      <ul class="hours-list">
        <li><span>Mon-Fri:</span> {HOURS.weekdays}</li>
        <li><span>Saturday:</span> {HOURS.saturday}</li>
        <li><span>Sunday:</span> {HOURS.sunday}</li>
      </ul>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <p>&copy; {currentYear} {SITE_TITLE}. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: var(--bg-dark);
    color: var(--text-white);
    padding-top: 4rem;
  }

  .footer-content {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 2rem 3rem;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.25fr;
    gap: 3rem;
  }

  /* Brand Column */
  .footer-logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .footer-logo:hover .footer-logo-img {
    opacity: 0.85;
  }

  .footer-tagline {
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-full);
    color: var(--text-white);
    transition: all var(--transition-fast);
  }

  .social-links a:hover {
    background: var(--accent);
    transform: translateY(-3px);
  }

  /* Column Headers */
  .footer-column h4 {
    color: var(--text-white);
    font-size: 1.1rem;
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  .hours-title {
    margin-top: 1.5rem;
  }

  /* Links */
  .footer-column ul {
    list-style: none;
  }

  .footer-column ul li {
    margin-bottom: 0.75rem;
  }

  .footer-column ul a {
    color: var(--text-light);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-column ul a:hover {
    color: var(--accent-light);
  }

  /* Contact List */
  .contact-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-light);
  }

  .contact-list svg {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* Hours List */
  .hours-list li {
    color: var(--text-light);
    font-size: 0.9rem;
  }

  .hours-list span {
    color: var(--text-white);
    font-weight: 500;
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.5rem 2rem;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--text-light);
    font-size: 0.9rem;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .footer-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1.5rem 2rem;
    }

    .footer-brand {
      grid-column: span 1;
    }

    .footer-bottom {
      padding: 1.5rem 1rem;
    }
  }
</style>
