---
import { CONTACT } from '../../consts';
---

<section class="quote-section">
  <div class="container">
    <div class="quote-grid">
      <!-- Left Side - Text -->
      <div class="quote-text">
        <h2>We're Here to Help!</h2>
        <p>
          Whether it's a quick fix or a bigger project, we're ready to tackle any job around your home.
          Our experienced team provides quality workmanship at competitive prices.
        </p>
        <ul class="benefits-list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Free, no-obligation quotes
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Fully insured for your peace of mind
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Reliable, professional service
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Satisfaction guaranteed
          </li>
        </ul>
      </div>

      <!-- Right Side - CTA Card -->
      <div class="quote-card">
        <h3>Get a Free Quote</h3>
        <p>Ready to get started? Give us a call or fill out our online form.</p>

        <a href={`tel:${CONTACT.phone.replace(/\D/g, '')}`} class="phone-cta">
          <div class="phone-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div class="phone-text">
            <span class="label">Or Give Us a Call</span>
            <span class="number">{CONTACT.phone}</span>
          </div>
        </a>

        <div class="divider">
          <span>or</span>
        </div>

        <a href="/quote" class="btn btn-primary btn-block">
          Submit Request Online
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-section {
    padding: 5rem 0;
    background: var(--bg-white);
  }

  .quote-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: center;
  }

  .quote-text h2 {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .quote-text > p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .benefits-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.05rem;
    color: var(--text-primary);
  }

  /* Quote Card */
  .quote-card {
    background: var(--bg-light);
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    border: 2px solid var(--border-light);
  }

  .quote-card h3 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .quote-card > p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .phone-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-white);
    border: 2px solid var(--accent);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .phone-cta:hover {
    background: var(--accent);
  }

  .phone-cta:hover .phone-icon,
  .phone-cta:hover .phone-text {
    color: var(--text-white);
  }

  .phone-icon {
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-lighter);
    border-radius: var(--radius-md);
    color: var(--accent);
    transition: all var(--transition-fast);
  }

  .phone-cta:hover .phone-icon {
    background: var(--accent-dark);
  }

  .phone-text {
    display: flex;
    flex-direction: column;
  }

  .phone-text .label {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .phone-text .number {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent);
  }

  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.5rem 0;
    color: var(--text-light);
  }

  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border-light);
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .quote-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .quote-card {
      max-width: 450px;
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    .quote-section {
      padding: 3rem 0;
    }

    .quote-text h2 {
      font-size: 2rem;
    }

    .quote-card {
      padding: 1.5rem;
    }
  }
</style>
