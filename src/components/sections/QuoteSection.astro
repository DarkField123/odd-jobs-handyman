<section class="quote-section">
  <div class="container">
    <div class="quote-grid">
      <!-- Left Side - Text -->
      <div class="quote-text">
        <h2>We're Here to Help!</h2>
        <p>
          Whether it's a quick fix or a bigger project, we're ready to tackle any job around your home.
          Our experienced team provides quality workmanship at competitive prices.
        </p>
        <ul class="benefits-list">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Free, no-obligation quotes
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Fully insured for your peace of mind
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Reliable, professional service
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Satisfaction guaranteed
          </li>
        </ul>
      </div>

      <!-- Right Side - CTA Card -->
      <div class="quote-card">
        <h3>Get a Free Quote</h3>
        <p>Ready to get started? Fill out our online form and we'll get back to you within 24 hours.</p>

        <a href="/quote" class="btn btn-primary btn-block">
          Request a Free Quote
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-section {
    padding: 5rem 0;
    background: var(--bg-white);
  }

  .quote-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: center;
  }

  .quote-text h2 {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .quote-text > p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .benefits-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.05rem;
    color: var(--text-primary);
  }

  /* Quote Card */
  .quote-card {
    background: var(--bg-light);
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    border: 2px solid var(--border-light);
  }

  .quote-card h3 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .quote-card > p {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .btn-block {
    display: block;
    width: 100%;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .quote-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .quote-card {
      max-width: 450px;
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    .quote-section {
      padding: 3rem 0;
    }

    .quote-text h2 {
      font-size: 2rem;
    }

    .quote-card {
      padding: 1.5rem;
    }
  }
</style>
