---
import { SITE_TITLE, CONTACT } from '../../consts';
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-text">
      <h1>
        <span class="brand-name">{SITE_TITLE}</span> &
        <br />Handyman Services
      </h1>
      <p class="hero-tagline">
        Your trusted local handyman for all home repairs and improvements.
        Quality workmanship, fair prices, and reliable service you can count on.
      </p>
      <div class="hero-actions">
        <a href="/quote" class="btn btn-primary btn-lg">
          Get a Free Quote
        </a>
        <a href={`tel:${CONTACT.phone.replace(/\D/g, '')}`} class="btn btn-secondary btn-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {CONTACT.phone}
        </a>
      </div>
    </div>
    <div class="hero-image">
      <!-- Toolbox SVG Illustration -->
      <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" class="toolbox-illustration">
        <!-- Toolbox Body -->
        <rect x="50" y="120" width="300" height="140" rx="10" fill="#E53935"/>
        <rect x="50" y="120" width="300" height="40" rx="10" fill="#C62828"/>

        <!-- Handle -->
        <rect x="160" y="100" width="80" height="30" rx="5" fill="#424242"/>
        <rect x="175" y="90" width="50" height="20" rx="3" fill="#616161"/>

        <!-- Toolbox Details -->
        <rect x="70" y="170" width="260" height="5" fill="#C62828"/>
        <circle cx="100" cy="140" r="8" fill="#FFC107"/>
        <circle cx="300" cy="140" r="8" fill="#FFC107"/>

        <!-- Tools Sticking Out -->
        <!-- Hammer -->
        <rect x="80" y="60" width="12" height="70" rx="2" fill="#8D6E63"/>
        <rect x="70" y="40" width="32" height="25" rx="3" fill="#607D8B"/>

        <!-- Screwdriver -->
        <rect x="130" y="50" width="8" height="80" rx="2" fill="#FFC107"/>
        <polygon points="134,50 126,30 142,30" fill="#607D8B"/>

        <!-- Wrench -->
        <rect x="180" y="55" width="10" height="75" rx="2" fill="#9E9E9E"/>
        <circle cx="185" cy="55" r="15" fill="none" stroke="#9E9E9E" stroke-width="8"/>

        <!-- Pliers -->
        <path d="M240 80 L250 50 L260 80 L250 90 Z" fill="#F44336"/>
        <rect x="246" y="90" width="8" height="40" rx="2" fill="#424242"/>

        <!-- Measuring Tape -->
        <circle cx="310" cy="70" r="25" fill="#FFC107"/>
        <circle cx="310" cy="70" r="15" fill="#FFE082"/>
        <rect x="295" y="90" width="30" height="8" fill="#FFC107"/>
      </svg>
    </div>
  </div>

  <!-- Decorative Background -->
  <div class="hero-bg-pattern"></div>
</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(135deg, var(--bg-light) 0%, var(--bg-white) 100%);
    padding: 4rem 0 6rem;
    overflow: hidden;
  }

  .hero-content {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    position: relative;
    z-index: 2;
  }

  .hero-text h1 {
    font-size: 3rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .brand-name {
    color: var(--accent);
  }

  .hero-tagline {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }

  .hero-image {
    position: relative;
    z-index: 2;
  }

  .toolbox-illustration {
    width: 100%;
    max-width: 450px;
    height: auto;
    filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.15));
  }

  .hero-bg-pattern {
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: radial-gradient(circle at 70% 30%, rgba(229, 57, 53, 0.05) 0%, transparent 50%);
    z-index: 1;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-text h1 {
      font-size: 2.5rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-image {
      order: -1;
    }

    .toolbox-illustration {
      max-width: 350px;
      margin: 0 auto;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    .hero-content {
      padding: 0 1.5rem;
    }

    .hero-text h1 {
      font-size: 2rem;
    }

    .hero-tagline {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn-lg {
      width: 100%;
      justify-content: center;
    }

    .toolbox-illustration {
      max-width: 280px;
    }
  }
</style>
