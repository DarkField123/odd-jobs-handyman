---

<section class="cta-banner">
  <div class="container">
    <div class="cta-content">
      <h2>Get a Free Quote Today!</h2>
      <p>No job too big or too small. Fill out our form for a free, no-obligation estimate.</p>

      <div class="cta-actions">
        <a href="/quote" class="btn btn-white">
          Request a Free Quote
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    padding: 4rem 0;
    text-align: center;
  }

  .cta-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 2.5rem;
    color: var(--text-white);
    margin-bottom: 1rem;
  }

  .cta-content > p {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .btn-white {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .cta-banner {
      padding: 3rem 0;
    }

    .cta-content h2 {
      font-size: 1.75rem;
    }

    .cta-content > p {
      font-size: 1rem;
    }

    .cta-actions {
      flex-direction: column;
      gap: 1rem;
    }

    .cta-phone,
    .btn-white {
      width: 100%;
      justify-content: center;
    }
  }
</style>
