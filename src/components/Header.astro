---
import { SITE_TITLE, NAV_LINKS, CONTACT } from '../consts';
import WrenchIcon from './icons/WrenchIcon.astro';
---

<header>
  <nav class="nav-container">
    <!-- Logo -->
    <a href="/" class="logo">
      <WrenchIcon size="1.75em" color="var(--accent)" />
      <span>{SITE_TITLE}</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="nav-links">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { 'nav-link-cta': link.href === '/quote' }]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Phone Number (Desktop) -->
    <a href={`tel:${CONTACT.phone.replace(/\D/g, '')}`} class="phone-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span>{CONTACT.phone}</span>
    </a>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger"></span>
      <span class="hamburger"></span>
      <span class="hamburger"></span>
    </button>
  </nav>

  <!-- Mobile Navigation -->
  <div class="mobile-nav">
    <div class="mobile-nav-links">
      {NAV_LINKS.map((link) => (
        <a href={link.href} class="mobile-nav-link">
          {link.label}
        </a>
      ))}
      <a href={`tel:${CONTACT.phone.replace(/\D/g, '')}`} class="mobile-phone-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Call {CONTACT.phone}
      </a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.querySelector('.mobile-menu-btn');
  const mobileNav = document.querySelector('.mobile-nav');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  menuBtn?.addEventListener('click', () => {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
    menuBtn.classList.toggle('active');
    mobileNav?.classList.toggle('active');
  });

  // Close menu when clicking a link
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      menuBtn?.classList.remove('active');
      menuBtn?.setAttribute('aria-expanded', 'false');
      mobileNav?.classList.remove('active');
    });
  });

  // Close menu on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (!menuBtn?.contains(target) && !mobileNav?.contains(target)) {
      menuBtn?.classList.remove('active');
      menuBtn?.setAttribute('aria-expanded', 'false');
      mobileNav?.classList.remove('active');
    }
  });
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-white);
    box-shadow: var(--shadow-sm);
  }

  .nav-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--accent);
  }

  /* Desktop Nav Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-link {
    padding: 0.5rem 1rem;
    color: var(--text-primary);
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--accent);
    background: var(--bg-light);
  }

  .nav-link-cta {
    background: var(--accent);
    color: var(--text-white) !important;
    padding: 0.5rem 1.25rem;
  }

  .nav-link-cta:hover {
    background: var(--accent-dark);
    color: var(--text-white) !important;
  }

  /* Phone Link */
  .phone-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .phone-link:hover {
    color: var(--accent-dark);
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    cursor: pointer;
    z-index: 101;
  }

  .hamburger {
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--transition-normal);
  }

  .mobile-menu-btn.active .hamburger:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .mobile-menu-btn.active .hamburger:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-btn.active .hamburger:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Mobile Navigation */
  .mobile-nav {
    display: none;
    position: fixed;
    top: 0;
    right: -100%;
    width: 80%;
    max-width: 320px;
    height: 100vh;
    background: var(--bg-white);
    box-shadow: var(--shadow-lg);
    padding: 5rem 1.5rem 2rem;
    transition: right var(--transition-normal);
    z-index: 99;
  }

  .mobile-nav.active {
    right: 0;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mobile-nav-link {
    padding: 1rem;
    color: var(--text-primary);
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .mobile-nav-link:hover {
    color: var(--accent);
    background: var(--bg-light);
  }

  .mobile-phone-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    padding: 1rem;
    background: var(--accent);
    color: var(--text-white);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  .mobile-phone-link:hover {
    background: var(--accent-dark);
    color: var(--text-white);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .nav-links,
    .phone-link {
      display: none;
    }

    .mobile-menu-btn,
    .mobile-nav {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .nav-container {
      padding: 1rem;
    }

    .logo {
      font-size: 1.25rem;
    }
  }
</style>
