# Firebase Client Configuration (Public - safe to commit)
PUBLIC_FIREBASE_API_KEY=your-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Firebase Admin (for seed scripts - keep secret!)
# Base64-encode your service account JSON:
#   node -e "console.log(Buffer.from(require('fs').readFileSync('path/to/key.json')).toString('base64'))"
FIREBASE_SERVICE_ACCOUNT=base64-encoded-service-account-json
